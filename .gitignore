# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# compressed geojson for electron builds (generated by electron:compress-geo)
public/geojson/snapshots/*.json.gz

# production (electron-builder output lives under /dist, not /build)
/build/*
!/build/icon.*
!/build/README.md

# electron
/dist/
/electron/dist/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# database
/data/
*.db

# validation reports
data/validation-report.json

# temp files
tmp_*.json

# python cache
__pycache__/
