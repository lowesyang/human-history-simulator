{
  "name": "human-history-simulator",
  "version": "0.3.0",
  "private": true,
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "seed": "npx tsx scripts/seed-db.ts",
    "seed:era": "npx tsx scripts/seed-db.ts",
    "generate:eras": "npx tsx scripts/generate-era-states.ts",
    "build:geo": "npx tsx scripts/build-geo-snapshots.ts",
    "electron:compile": "esbuild electron/main.ts --bundle --platform=node --outfile=electron/dist/main.js --external:electron --format=cjs && esbuild electron/preload.ts --bundle --platform=node --outfile=electron/dist/preload.js --external:electron --format=cjs",
    "electron:compress-geo": "node scripts/compress-geo.js",
    "electron:prebuild": "npm run build && npm run electron:compile && npm run electron:compress-geo",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && npm run electron:compile && electron .\"",
    "electron:build": "npm run electron:prebuild && electron-builder --publish never",
    "electron:build:mac": "npm run electron:prebuild && electron-builder --mac --publish never",
    "electron:build:win": "npm run electron:prebuild && electron-builder --win --publish never",
    "electron:build:linux": "npm run electron:prebuild && electron-builder --linux --publish never",
    "electron:publish": "npm run electron:prebuild && electron-builder --publish always",
    "validate:events": "npx tsx scripts/validate-community-events.ts",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui"
  },
  "dependencies": {
    "@turf/helpers": "^7.3.4",
    "@turf/simplify": "^7.3.4",
    "@vis.gl/react-maplibre": "^8.1.0",
    "better-sqlite3": "^12.6.2",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "electron-updater": "^6.6.2",
    "maplibre-gl": "^5.19.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.1.2",
    "electron": "^35.0.1",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.27.4",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^8.0.3"
  }
}